@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Phòng Trọ VN</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body {
        font-family: 'Inter', sans-serif;
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center p-4">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-lg p-8 border border-gray-100">
        <div class="text-center mb-8">
            <h1 class="text-3xl font-bold text-[#006591] mb-2">Phòng Trọ VN</h1>
            <p class="text-gray-500">Đăng nhập để vào hệ thống quản lý</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="bg-red-50 text-red-600 p-3 rounded-lg text-sm font-medium mb-6 border border-red-100 text-center">
                @ViewBag.Error
            </div>
        }

        <form action="/TaiKhoan/Login" method="POST" class="space-y-5">
            @Html.AntiForgeryToken()
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1">Email</label>
                <input type="email" name="email" required placeholder="Nhập email của bạn"
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#006591] focus:border-[#006591] outline-none transition-all" />
            </div>
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1">Mật khẩu</label>
                <input type="password" name="password" required placeholder="Nhập mật khẩu"
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:ring-2 focus:ring-[#006591] focus:border-[#006591] outline-none transition-all" />
            </div>
            <button type="submit" class="w-full bg-[#006591] hover:bg-[#005175] text-white font-bold py-3 px-4 rounded-lg transition-colors mt-4">
                Đăng nhập
            </button>
        </form>
    </div>
</body>
</html>