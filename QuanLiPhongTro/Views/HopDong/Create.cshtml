@{
    ViewData["Title"] = "Thêm hợp đồng mới";
    Layout = "_Layout";
}

<div class="max-w-3xl mx-auto bg-white p-8 rounded-xl shadow-sm border mt-6">
    <div class="flex items-center gap-3 mb-6 border-b pb-4">
        <span class="material-symbols-outlined text-primary text-3xl">contract</span>
        <div>
            <h2 class="text-2xl font-bold text-gray-800">Lập Hợp Đồng Mới</h2>
            <p class="text-sm text-gray-500">Mã Sinh Viên: 2415053122232</p>
        </div>
    </div>

    <form action="/HopDong/Create" method="post" class="space-y-5">

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
                <label class="block font-bold mb-1 text-sm text-gray-700">Mã hợp đồng</label>
                <input type="text" name="MaHopDong" placeholder="VD: HD-001" required class="w-full p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none" />
            </div>

            <div>
                <label class="block font-bold mb-1 text-sm text-gray-700">Trạng thái</label>
                <select name="TrangThai" class="w-full p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none">
                    <option value="Hiệu lực">Hiệu lực</option>
                    <option value="Chờ ký">Chờ ký</option>
                    <option value="Hết hạn">Hết hạn</option>
                </select>
            </div>
        </div>

        <div>
            <label class="block font-bold mb-1 text-sm text-gray-700">Chọn Khách Thuê</label>
            <select name="MaKhachThue" required class="w-full p-2.5 border border-gray-300 rounded-lg bg-gray-50 focus:bg-white focus:ring-2 focus:ring-primary outline-none">
                <option value="">-- Bấm để chọn người thuê --</option>
                @if (ViewBag.KhachThueList != null)
                {
                    foreach (System.Data.DataRow row in ViewBag.KhachThueList.Rows)
                    {
                        <option value="@row["MaKhachThue"]">
                            Mã: @row["MaKhachThue"] - Tên: @row["HoTen"] (CCCD: @row["CCCD"])
                        </option>
                    }
                }
            </select>
        </div>

        <div>
            <label class="block font-bold mb-1 text-sm text-gray-700">Chọn Phòng Cho Thuê</label>
            <select name="MaPhong" required class="w-full p-2.5 border border-gray-300 rounded-lg bg-gray-50 focus:bg-white focus:ring-2 focus:ring-primary outline-none">
                <option value="">-- Bấm để chọn phòng --</option>
                @if (ViewBag.PhongList != null)
                {
                    foreach (System.Data.DataRow row in ViewBag.PhongList.Rows)
                    {
                        <option value="@row["MaPhong"]">Phòng: @row["TenPhong"]</option>
                    }
                }
            </select>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
                <label class="block font-bold mb-1 text-sm text-gray-700">Ngày bắt đầu</label>
                <input type="date" name="NgayBatDau" value="@DateTime.Now.ToString("yyyy-MM-dd")" required class="w-full p-2.5 border border-gray-300 rounded-lg" />
            </div>

            <div>
                <label class="block font-bold mb-1 text-sm text-gray-700">Ngày kết thúc</label>
                <input type="date" name="NgayKetThuc" required class="w-full p-2.5 border border-gray-300 rounded-lg" />
            </div>
        </div>

        <div class="bg-blue-50 p-4 rounded-lg border border-blue-100">
            <div>
                <label class="block font-bold mb-1 text-sm text-gray-700">Tiền đặt cọc (VNĐ)</label>
                <input type="number" name="TienCoc" placeholder="Ví dụ: 3000000" required class="w-full p-2.5 border border-gray-300 rounded-lg" />
            </div>
        </div>

        <div class="flex items-center gap-3 mt-6 pt-6 border-t">
            <button type="submit" class="bg-[#006591] hover:bg-blue-800 text-white px-8 py-2.5 rounded-lg font-bold shadow-sm transition-colors flex items-center gap-2">
                <span class="material-symbols-outlined text-[20px]">save</span> Lưu hợp đồng
            </button>
            <a href="/HopDong/Index" class="bg-gray-100 hover:bg-gray-200 text-gray-700 px-8 py-2.5 rounded-lg font-bold transition-colors">Hủy</a>
        </div>
    </form>
</div>