@{
    ViewData["Title"] = "Chi tiết phòng trọ";
    Layout = "_UserLayout";
}

<div class="mb-6">
    <a href="/UserPhong" class="text-primary hover:underline text-sm font-bold flex items-center gap-1 w-fit">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span>
        Trở lại danh sách
    </a>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="h-64 bg-blue-50 flex flex-col items-center justify-center text-primary relative group cursor-pointer border-b border-gray-100">
        <span class="material-symbols-outlined text-5xl mb-2 text-primary/50">image</span>
        <span class="text-sm font-bold text-primary/70">Ảnh Toàn Cảnh Phòng 101 VIP</span>
        <span class="absolute bottom-4 right-4 bg-white/90 px-3 py-1.5 rounded-lg text-sm font-bold flex items-center gap-1 shadow-sm">
            <span class="material-symbols-outlined text-[18px]">photo_library</span>
            Xem tất cả 5 ảnh
        </span>
    </div>

    <div class="p-8">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6 pb-6 border-b border-gray-100">
            <div>
                <div class="flex items-center gap-2 mb-2">
                    <span class="px-2 py-1 bg-blue-100 text-primary text-xs font-bold rounded uppercase tracking-wide">Phòng Trọ</span>
                    <span class="px-2 py-1 bg-green-100 text-green-700 text-xs font-bold rounded uppercase tracking-wide">Đang trống</span>
                </div>
                <h1 class="text-3xl font-bold text-on-surface">Phòng 101 VIP</h1>
                <p class="text-gray-500 mt-2 flex items-center gap-1">
                    <span class="material-symbols-outlined text-[18px]">location_on</span>
                    123 Nguyễn Văn Linh, Quận 7, TP.HCM
                </p>
            </div>
            <div class="text-left md:text-right">
                <p class="text-3xl font-bold text-primary">3,500,000 ₫ <span class="text-sm font-normal text-gray-500">/tháng</span></p>
                <p class="text-sm text-gray-500 mt-1 font-medium">Cọc 1 tháng</p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-8">
                <div>
                    <h3 class="text-lg font-bold text-on-surface mb-3 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">description</span>
                        Mô tả chi tiết
                    </h3>
                    <p class="text-sm text-gray-600 leading-relaxed">
                        Phòng trọ rộng rãi, thoáng mát, có cửa sổ lớn đón ánh sáng tự nhiên. Nằm trong khu vực an ninh, yên tĩnh, gần chợ, siêu thị và các trường đại học lớn. Giờ giấc tự do, không chung chủ, hệ thống camera an ninh 24/7. Phù hợp cho sinh viên hoặc người đi làm mong muốn một không gian sống sạch sẽ, hiện đại.
                    </p>
                </div>

                <div>
                    <h3 class="text-lg font-bold text-on-surface mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">chair</span>
                        Tiện ích sẵn có
                    </h3>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                        <div class="flex items-center gap-2 text-sm font-medium text-gray-700 p-3 bg-gray-50 rounded-lg border border-gray-100">
                            <span class="material-symbols-outlined text-primary text-[20px]">wifi</span> Wifi miễn phí
                        </div>
                        <div class="flex items-center gap-2 text-sm font-medium text-gray-700 p-3 bg-gray-50 rounded-lg border border-gray-100">
                            <span class="material-symbols-outlined text-primary text-[20px]">ac_unit</span> Máy lạnh
                        </div>
                        <div class="flex items-center gap-2 text-sm font-medium text-gray-700 p-3 bg-gray-50 rounded-lg border border-gray-100">
                            <span class="material-symbols-outlined text-primary text-[20px]">directions_car</span> Chỗ để xe
                        </div>
                        <div class="flex items-center gap-2 text-sm font-medium text-gray-700 p-3 bg-gray-50 rounded-lg border border-gray-100">
                            <span class="material-symbols-outlined text-primary text-[20px]">kitchen</span> Tủ lạnh
                        </div>
                        <div class="flex items-center gap-2 text-sm font-medium text-gray-700 p-3 bg-gray-50 rounded-lg border border-gray-100">
                            <span class="material-symbols-outlined text-primary text-[20px]">shower</span> Vệ sinh riêng
                        </div>
                        <div class="flex items-center gap-2 text-sm font-medium text-gray-700 p-3 bg-gray-50 rounded-lg border border-gray-100">
                            <span class="material-symbols-outlined text-primary text-[20px]">local_laundry_service</span> Máy giặt chung
                        </div>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-1">
                <div class="bg-gray-50 p-6 rounded-xl border border-gray-200">
                    <h3 class="text-lg font-bold text-on-surface mb-4">Thông tin thêm</h3>
                    <ul class="space-y-3 text-sm text-gray-700">
                        <li class="flex justify-between items-center py-2 border-b border-gray-200/60">
                            <span class="text-gray-500">Diện tích</span>
                            <span class="font-bold text-on-surface">30 m²</span>
                        </li>
                        <li class="flex justify-between items-center py-2 border-b border-gray-200/60">
                            <span class="text-gray-500">Tầng</span>
                            <span class="font-bold text-on-surface">Trệt</span>
                        </li>
                        <li class="flex justify-between items-center py-2 border-b border-gray-200/60">
                            <span class="text-gray-500">Sức chứa</span>
                            <span class="font-bold text-on-surface">Tối đa 3 người</span>
                        </li>
                        <li class="flex justify-between items-center py-2 border-b border-gray-200/60">
                            <span class="text-gray-500">Điện</span>
                            <span class="font-bold text-on-surface">3,500 đ/kwh</span>
                        </li>
                        <li class="flex justify-between items-center py-2">
                            <span class="text-gray-500">Nước</span>
                            <span class="font-bold text-on-surface">100,000 đ/người</span>
                        </li>
                    </ul>

                    <div class="mt-8 space-y-3">
                        <button class="w-full py-3 bg-primary text-white rounded-lg font-bold hover:bg-primary/90 transition-colors flex items-center justify-center gap-2 shadow-sm">
                            <span class="material-symbols-outlined text-[20px]">edit_document</span>
                            Đăng ký thuê ngay
                        </button>
                        <button class="w-full py-3 bg-white border border-primary text-primary rounded-lg font-bold hover:bg-blue-50 transition-colors flex items-center justify-center gap-2 shadow-sm">
                            <span class="material-symbols-outlined text-[20px]">call</span>
                            Liên hệ chủ nhà
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>