@{
    ViewData["Title"] = "Thêm Khách Thuê"; Layout = "_Layout";
}
<div class="max-w-2xl mx-auto bg-white p-8 rounded-xl shadow-sm border border-gray-100">
    <h2 class="text-2xl font-bold text-gray-800 mb-6">Thêm khách thuê mới</h2>
    <form action="/KhachThue/Create" method="post" class="space-y-5">
        <div class="grid grid-cols-2 gap-5">
            <div><label class="block text-sm font-bold text-gray-700 mb-1">Mã khách</label><input type="text" name="MaKhachThue" required class="w-full px-4 py-2 border border-gray-300 rounded-lg outline-none focus:border-primary" placeholder="VD: KT004" /></div>
            <div><label class="block text-sm font-bold text-gray-700 mb-1">Họ và tên</label><input type="text" name="HoTen" required class="w-full px-4 py-2 border border-gray-300 rounded-lg outline-none focus:border-primary" /></div>
            <div><label class="block text-sm font-bold text-gray-700 mb-1">Số điện thoại</label><input type="text" name="SoDienThoai" class="w-full px-4 py-2 border border-gray-300 rounded-lg outline-none focus:border-primary" /></div>
            <div><label class="block text-sm font-bold text-gray-700 mb-1">Số CCCD</label><input type="text" name="CCCD" class="w-full px-4 py-2 border border-gray-300 rounded-lg outline-none focus:border-primary" /></div>
            <div><label class="block text-sm font-bold text-gray-700 mb-1">Ngày tham gia</label><input type="date" name="NgayThamGia" class="w-full px-4 py-2 border border-gray-300 rounded-lg outline-none focus:border-primary" /></div>
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1">Trạng thái</label>
                <select name="TrangThai" class="w-full px-4 py-2 border border-gray-300 rounded-lg outline-none focus:border-primary">
                    <option value="ĐANG THUÊ">Đang thuê</option>
                    <option value="HẾT HẠN">Hết hạn</option>
                </select>
            </div>
        </div>
        <div class="flex justify-end gap-3 mt-8 pt-4 border-t border-gray-100">
            <a href="/KhachThue/Index" class="px-6 py-2 text-gray-600 bg-gray-100 hover:bg-gray-200 rounded-lg font-bold">Hủy</a>
            <button type="submit" class="px-6 py-2 bg-primary text-white rounded-lg font-bold hover:bg-primary/90">Lưu khách thuê</button>
        </div>
    </form>
</div>