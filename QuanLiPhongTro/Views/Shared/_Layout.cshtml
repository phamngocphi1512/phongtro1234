<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@ViewData["Title"] - Phòng Trọ VN</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        "colors": {
        "surface-container-high": "#e4e8ee",
        "primary-container": "#0ea5e9",
        "outline": "#6e7881",
        "surface-container-highest": "#dee3e9",
        "surface-container-low": "#f0f4fa",
        "error": "#ba1a1a",
        "on-surface": "#171c20",
        "outline-variant": "#bec8d2",
        "surface-bright": "#f6faff",
        "secondary": "#505f76",
        "on-background": "#171c20",
        "on-surface-variant": "#3e4850",
        "surface": "#f6faff",
        "surface-variant": "#dee3e9",
        "background": "#f6faff",
        "primary": "#006591",
        "tertiary": "#8a5100"
        },
        "borderRadius": { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
        "spacing": { "stack-gap": "1.5rem", "inline-gap": "0.5rem", "grid-gutter": "1rem", "card-padding": "1.25rem", "container-padding": "2rem" },
        "fontFamily": { "h3": ["Inter"], "label-sm": ["Inter"], "body-sm": ["Inter"], "h1": ["Inter"], "label-md": ["Inter"], "body-lg": ["Inter"], "body-md": ["Inter"], "h2": ["Inter"] },
        "fontSize": {
        "h3": ["20px", {"lineHeight": "28px", "fontWeight": "600"}],
        "label-sm": ["12px", {"lineHeight": "16px", "fontWeight": "600"}],
        "body-sm": ["12px", {"lineHeight": "16px", "fontWeight": "400"}],
        "h1": ["30px", {"lineHeight": "38px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
        "label-md": ["14px", {"lineHeight": "20px", "fontWeight": "500"}],
        "body-lg": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
        "body-md": ["14px", {"lineHeight": "20px", "fontWeight": "400"}],
        "h2": ["24px", {"lineHeight": "32px", "letterSpacing": "-0.01em", "fontWeight": "600"}]
        }
        }
        }
        }
    </script>
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="bg-background text-on-background min-h-screen flex font-body-md">

    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "Home";
        string activeClass = "text-primary font-bold border-r-4 border-primary bg-primary-container/10";
        string inactiveClass = "text-on-surface-variant hover:text-primary hover:bg-secondary-container/50 transition-colors border-r-4 border-transparent";
    }

    <aside class="fixed left-0 top-0 h-full z-40 flex flex-col bg-surface docked w-[240px] shadow-sm bg-surface-container-low border-r border-outline-variant/30">
        <div class="p-container-padding pb-stack-gap">
            <h2 class="font-h2 text-h2 font-bold text-primary">Phòng Trọ VN</h2>
            <p class="font-body-sm text-body-sm text-on-surface-variant mt-1">SV: 2415053122232</p>
        </div>
        <nav class="flex-1 px-4 flex flex-col gap-1">
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg @(currentController == "Home" ? activeClass : inactiveClass)" href="/Home/Index">
                <span class="material-symbols-outlined">dashboard</span>
                <span class="font-label-md text-label-md">Tổng quan</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg @(currentController == "PhongTro" ? activeClass : inactiveClass)" href="/PhongTro/Index">
                <span class="material-symbols-outlined">door_front</span>
                <span class="font-label-md text-label-md">Phòng</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg @(currentController == "KhachThue" ? activeClass : inactiveClass)" href="/KhachThue/Index">
                <span class="material-symbols-outlined">group</span>
                <span class="font-label-md text-label-md">Khách thuê</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg @(currentController == "HopDong" ? activeClass : inactiveClass)" href="/HopDong/Index">
                <span class="material-symbols-outlined">description</span>
                <span class="font-label-md text-label-md">Hợp đồng</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg @(currentController == "ThanhToan" ? activeClass : inactiveClass)" href="/ThanhToan/Index">
                <span class="material-symbols-outlined">payments</span>
                <span class="font-label-md text-label-md">Thanh toán</span>
            </a>
            <a class="flex items-center gap-3 px-4 py-3 rounded-lg @(currentController == "YeuCau" ? activeClass : inactiveClass)" href="/YeuCau/Index">
                <span class="material-symbols-outlined">feedback</span>
                <span class="font-label-md text-label-md">Yêu cầu</span>
            </a>
        </nav>

        <div class="p-4 mt-auto">
            <a href="/UserDashboard/Index" class="flex items-center gap-3 p-3 rounded-lg bg-surface-container-highest hover:bg-surface-variant transition-colors cursor-pointer block">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-primary flex items-center justify-center text-white font-bold">
                        A
                    </div>
                    <div>
                        <p class="font-label-sm text-label-sm text-on-surface">Quản trị viên</p>
                        <p class="font-body-sm text-body-sm text-on-surface-variant">Sang Cổng User</p>
                    </div>
                </div>
            </a>
        </div>
    </aside>

    <div class="ml-[240px] flex-1 flex flex-col min-h-screen">
        <header class="sticky top-0 z-50 flex justify-between items-center px-container-padding h-16 w-full bg-surface border-b border-outline-variant">
            <div class="flex items-center gap-4 flex-1">
                <div class="relative w-64">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant" style="font-variation-settings: 'opsz' 20;">search</span>
                    <input class="w-full pl-10 pr-4 py-2 bg-surface-container-low border border-outline-variant rounded-lg font-body-sm text-body-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors" placeholder="Tìm kiếm..." type="text" />
                </div>
            </div>
            <div class="flex items-center gap-4">
                <button class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-highest transition-colors text-on-surface-variant">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
            </div>
        </header>

        <main class="flex-1 p-container-padding bg-background overflow-y-auto">
            @RenderBody()
        </main>
    </div>
</body>
</html>