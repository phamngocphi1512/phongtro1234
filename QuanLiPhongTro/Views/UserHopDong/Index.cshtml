@{
    ViewData["Title"] = "Hợp đồng của tôi";
    Layout = "_UserLayout";
}

<div class="mb-8">
    <h2 class="text-3xl font-bold text-on-surface">Hợp đồng của tôi</h2>
    <p class="text-base text-on-surface-variant mt-1">Quản lý và theo dõi các hợp đồng thuê phòng của bạn.</p>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="p-6 border-b border-gray-100 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-gray-50/50">
        <h3 class="text-lg font-bold text-on-surface flex items-center gap-2">
            <span class="material-symbols-outlined text-primary">description</span>
            Danh sách hợp đồng
        </h3>
        <div class="relative w-full sm:w-auto">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-[20px]">search</span>
            <input type="text" placeholder="Tìm mã hợp đồng..." class="pl-9 pr-4 py-2 w-full sm:w-64 border border-gray-200 rounded-lg text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors">
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 border-b border-gray-200 text-xs uppercase text-gray-500 font-bold tracking-wider">
                    <th class="p-4 whitespace-nowrap">Mã hợp đồng</th>
                    <th class="p-4 whitespace-nowrap">Phòng</th>
                    <th class="p-4 whitespace-nowrap">Thời hạn</th>
                    <th class="p-4 whitespace-nowrap">Tiền cọc</th>
                    <th class="p-4 whitespace-nowrap">Trạng thái</th>
                    <th class="p-4 text-center whitespace-nowrap">Thao tác</th>
                </tr>
            </thead>
            <tbody class="text-sm text-gray-700 divide-y divide-gray-100">
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="p-4 font-bold text-primary">HD-2023-001</td>
                    <td class="p-4 font-medium">Phòng 101 VIP</td>
                    <td class="p-4">15/08/2023 - 15/08/2024</td>
                    <td class="p-4 font-bold text-on-surface">3,500,000 ₫</td>
                    <td class="p-4">
                        <span class="inline-block px-3 py-1 bg-green-100 text-green-700 text-xs font-bold rounded-full border border-green-200">Đang hiệu lực</span>
                    </td>
                    <td class="p-4 text-center">
                        <div class="flex items-center justify-center gap-1">
                            <button class="text-primary hover:bg-blue-50 p-1.5 rounded-lg transition-colors" title="Xem chi tiết">
                                <span class="material-symbols-outlined text-[20px]">visibility</span>
                            </button>
                            <button class="text-primary hover:bg-blue-50 p-1.5 rounded-lg transition-colors" title="Tải xuống PDF">
                                <span class="material-symbols-outlined text-[20px]">download</span>
                            </button>
                        </div>
                    </td>
                </tr>

                <tr class="hover:bg-gray-50 transition-colors bg-gray-50/30">
                    <td class="p-4 font-bold text-gray-500">HD-2022-045</td>
                    <td class="p-4 text-gray-500">Phòng 202 Thường</td>
                    <td class="p-4 text-gray-500">01/01/2022 - 01/01/2023</td>
                    <td class="p-4 text-gray-500">2,500,000 ₫</td>
                    <td class="p-4">
                        <span class="inline-block px-3 py-1 bg-gray-100 text-gray-600 text-xs font-bold rounded-full border border-gray-200">Đã kết thúc</span>
                    </td>
                    <td class="p-4 text-center">
                        <div class="flex items-center justify-center gap-1">
                            <button class="text-gray-500 hover:bg-gray-200 p-1.5 rounded-lg transition-colors" title="Xem chi tiết">
                                <span class="material-symbols-outlined text-[20px]">visibility</span>
                            </button>
                            <button class="text-gray-500 hover:bg-gray-200 p-1.5 rounded-lg transition-colors" title="Tải xuống PDF">
                                <span class="material-symbols-outlined text-[20px]">download</span>
                            </button>
                        </div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="p-4 border-t border-gray-100 text-sm text-gray-500 flex justify-between items-center bg-gray-50/50">
        <span>Hiển thị 1 - 2 trong tổng số 2 hợp đồng</span>
    </div>
</div>