@{
    ViewData["Title"] = "Khám phá phòng trọ";
    Layout = "_UserLayout";
}

<div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
    <div>
        <h2 class="text-3xl font-bold text-on-surface mb-2">Khám phá phòng trọ</h2>
        <p class="text-base text-on-surface-variant">Tìm kiếm không gian lý tưởng cho bạn.</p>
    </div>
</div>

<div class="bg-white p-5 rounded-xl shadow-sm border border-gray-200 mb-8 flex flex-wrap gap-4 items-end">
    <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-bold text-gray-500 mb-1">Khu vực</label>
        <select class="w-full px-4 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none">
            <option>Tất cả quận/huyện</option>
            <option>Quận 1</option>
            <option>Quận 7</option>
        </select>
    </div>
    <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-bold text-gray-500 mb-1">Khoảng giá</label>
        <select class="w-full px-4 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none">
            <option>Mọi mức giá</option>
            <option>Dưới 3 triệu</option>
            <option>3 - 5 triệu</option>
        </select>
    </div>
    <div class="flex-1 min-w-[200px]">
        <label class="block text-xs font-bold text-gray-500 mb-1">Loại phòng</label>
        <select class="w-full px-4 py-2 bg-gray-50 border border-gray-300 rounded-lg text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none">
            <option>Tất cả loại hình</option>
            <option>Phòng trọ</option>
            <option>Chung cư mini</option>
        </select>
    </div>
    <button class="bg-primary hover:bg-primary/90 text-white px-6 py-2 rounded-lg text-sm font-bold transition-colors h-[42px]">
        Áp dụng bộ lọc
    </button>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow flex flex-col">
        <div class="h-48 bg-blue-100 flex items-center justify-center text-primary font-bold">
            Ảnh Phòng 101 VIP
        </div>
        <div class="p-5 flex-1 flex flex-col">
            <div class="flex justify-between items-start mb-2">
                <h3 class="text-xl font-bold text-on-surface">Phòng 101 VIP</h3>
                <span class="text-xl font-bold text-primary">3,500,000 đ</span>
            </div>
            <p class="text-sm text-gray-500 mb-4">Diện tích: 30 m² - Quận 7</p>
            <div class="mt-auto pt-2">
                <a href="/UserPhong/Detail" class="block w-full bg-blue-50 text-primary hover:bg-primary hover:text-white border border-blue-100 px-4 py-2 rounded-lg text-sm font-bold transition-colors text-center">
                    Xem chi tiết
                </a>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow flex flex-col">
        <div class="h-48 bg-blue-100 flex items-center justify-center text-primary font-bold">
            Ảnh Phòng 102
        </div>
        <div class="p-5 flex-1 flex flex-col">
            <div class="flex justify-between items-start mb-2">
                <h3 class="text-xl font-bold text-on-surface">Phòng 102 Tiêu chuẩn</h3>
                <span class="text-xl font-bold text-primary">2,500,000 đ</span>
            </div>
            <p class="text-sm text-gray-500 mb-4">Diện tích: 20 m² - Quận 7</p>
            <div class="mt-auto pt-2">
                <a href="/UserPhong/Detail" class="block w-full bg-blue-50 text-primary hover:bg-primary hover:text-white border border-blue-100 px-4 py-2 rounded-lg text-sm font-bold transition-colors text-center">
                    Xem chi tiết
                </a>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden hover:shadow-md transition-shadow flex flex-col">
        <div class="h-48 bg-blue-100 flex items-center justify-center text-primary font-bold">
            Ảnh Phòng 201
        </div>
        <div class="p-5 flex-1 flex flex-col">
            <div class="flex justify-between items-start mb-2">
                <h3 class="text-xl font-bold text-on-surface">Phòng 201 Giá rẻ</h3>
                <span class="text-xl font-bold text-primary">1,800,000 đ</span>
            </div>
            <p class="text-sm text-gray-500 mb-4">Diện tích: 15 m² - Quận 1</p>
            <div class="mt-auto pt-2">
                <a href="/UserPhong/Detail" class="block w-full bg-blue-50 text-primary hover:bg-primary hover:text-white border border-blue-100 px-4 py-2 rounded-lg text-sm font-bold transition-colors text-center">
                    Xem chi tiết
                </a>
            </div>
        </div>
    </div>
</div>