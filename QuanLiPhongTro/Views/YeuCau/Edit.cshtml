@model System.Data.DataRow
@{
    ViewData["Title"] = "Cập nhật yêu cầu"; Layout = "_Layout";
}
<div class="max-w-2xl mx-auto bg-white p-8 rounded-xl shadow-sm border mt-6">
    <h2 class="text-2xl font-bold mb-6">Cập nhật yêu cầu: @Model["MaYeuCau"]</h2>
    <form action="/YeuCau/Edit" method="post" class="space-y-4">
        <input type="hidden" name="MaYeuCau" value="@Model["MaYeuCau"]" />
        <div><label class="block font-bold mb-1">Tiêu đề sự cố</label><input type="text" name="TieuDe" value="@Model["TieuDe"]" required class="w-full p-2 border rounded-lg" /></div>
        <div><label class="block font-bold mb-1">Mô tả chi tiết</label><textarea name="MoTa" rows="3" class="w-full p-2 border rounded-lg">@Model["MoTa"]</textarea></div>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block font-bold mb-1">Ưu tiên</label>
                <select name="UuTien" class="w-full p-2 border rounded-lg">
                    <option value="Thấp" selected="@(Model["UuTien"].ToString() == "Thấp")">Thấp</option>
                    <option value="Trung bình" selected="@(Model["UuTien"].ToString() == "Trung bình")">Trung bình</option>
                    <option value="Cao" selected="@(Model["UuTien"].ToString() == "Cao")">Cao</option>
                </select>
            </div>
            <div>
                <label class="block font-bold mb-1">Trạng thái</label>
                <select name="TrangThai" class="w-full p-2 border rounded-lg">
                    <option value="Đang chờ" selected="@(Model["TrangThai"].ToString() == "Đang chờ")">Đang chờ</option>
                    <option value="Đang xử lý" selected="@(Model["TrangThai"].ToString() == "Đang xử lý")">Đang xử lý</option>
                    <option value="Đã hoàn thành" selected="@(Model["TrangThai"].ToString() == "Đã hoàn thành")">Đã hoàn thành</option>
                </select>
            </div>
        </div>
        <div class="flex gap-2 mt-4 pt-4 border-t">
            <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg font-bold">Cập nhật</button>
            <a href="/YeuCau/Index" class="bg-gray-200 px-6 py-2 rounded-lg font-bold">Hủy</a>
        </div>
    </form>
</div>