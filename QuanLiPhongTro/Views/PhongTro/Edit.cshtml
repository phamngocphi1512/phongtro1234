@model System.Data.DataRow

@{
    ViewData["Title"] = "Chỉnh sửa phòng";
    Layout = "_Layout";
}

<div class="mb-4">
    <h1 class="font-h1 text-2xl font-bold text-on-surface">Chỉnh sửa phòng: @Model["MaPhong"]</h1>
</div>

<div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200 max-w-3xl">
    <form action="/PhongTro/Edit" method="post" class="space-y-4">
        <input type="hidden" name="MaPhong" value="@Model["MaPhong"]" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1">Tên / Vị trí phòng</label>
                <input type="text" name="TenPhong" value="@Model["TenPhong"]" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-primary focus:border-primary outline-none" />
            </div>
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1">Mã loại phòng</label>
                <input type="text" name="MaLoai" value="@Model["MaLoai"]" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-primary focus:border-primary outline-none" />
            </div>
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1">Diện tích (m2)</label>
                <input type="number" name="DienTich" value="@Model["DienTich"]" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-primary focus:border-primary outline-none" />
            </div>
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1">Giá thuê (VNĐ)</label>
                <input type="number" name="GiaThue" value="@Model["GiaThue"]" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-primary focus:border-primary outline-none" />
            </div>
            <div>
                <label class="block text-sm font-bold text-gray-700 mb-1">Trạng thái</label>
                <select name="TrangThai" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-primary focus:border-primary outline-none">
                    <option value="Đang trống" selected="@(Model["TrangThai"].ToString() == "Đang trống")">Đang trống</option>
                    <option value="Đã thuê" selected="@(Model["TrangThai"].ToString() == "Đã thuê")">Đã thuê</option>
                    <option value="Bảo trì" selected="@(Model["TrangThai"].ToString() == "Bảo trì")">Bảo trì</option>
                </select>
            </div>
        </div>
        <div class="flex gap-2 mt-6 pt-4 border-t border-gray-100">
            <button type="submit" class="bg-primary text-white px-6 py-2 rounded-lg font-bold hover:bg-primary/90 transition-colors">Lưu thay đổi</button>
            <a href="/PhongTro/Index" class="bg-gray-100 text-gray-700 px-6 py-2 rounded-lg font-bold hover:bg-gray-200 transition-colors flex items-center">Hủy</a>
        </div>
    </form>
</div>  