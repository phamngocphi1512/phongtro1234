@{
    ViewData["Title"] = "Tạo yêu cầu"; Layout = "_Layout";
}
<div class="max-w-2xl mx-auto bg-white p-8 rounded-xl shadow-sm border mt-6">
    <h2 class="text-2xl font-bold mb-6">Tạo yêu cầu sửa chữa - SV: 2415053122232</h2>
    <form action="/YeuCau/Create" method="post" class="space-y-4">
        <div><label class="block font-bold mb-1">Mã Yêu Cầu</label><input type="text" name="MaYeuCau" required class="w-full p-2 border rounded-lg" /></div>
        <div class="grid grid-cols-2 gap-4">
            <div><label class="block font-bold mb-1">Mã Khách (Tham chiếu)</label><input type="text" name="MaKhachThue" required class="w-full p-2 border rounded-lg" /></div>
            <div><label class="block font-bold mb-1">Mã Phòng (Tham chiếu)</label><input type="text" name="MaPhong" required class="w-full p-2 border rounded-lg" /></div>
        </div>
        <div><label class="block font-bold mb-1">Tiêu đề sự cố</label><input type="text" name="TieuDe" required class="w-full p-2 border rounded-lg" /></div>
        <div><label class="block font-bold mb-1">Mô tả chi tiết</label><textarea name="MoTa" rows="3" class="w-full p-2 border rounded-lg"></textarea></div>
        <div class="grid grid-cols-2 gap-4">
            <div>
                <label class="block font-bold mb-1">Ưu tiên</label>
                <select name="UuTien" class="w-full p-2 border rounded-lg">
                    <option value="Thấp">Thấp</option>
                    <option value="Trung bình">Trung bình</option>
                    <option value="Cao">Cao</option>
                </select>
            </div>
            <div>
                <label class="block font-bold mb-1">Trạng thái</label>
                <select name="TrangThai" class="w-full p-2 border rounded-lg">
                    <option value="Đang chờ">Đang chờ</option>
                    <option value="Đang xử lý">Đang xử lý</option>
                    <option value="Đã hoàn thành">Đã hoàn thành</option>
                </select>
            </div>
        </div>
        <div class="flex gap-2 mt-4 pt-4 border-t">
            <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg font-bold">Lưu yêu cầu</button>
            <a href="/YeuCau/Index" class="bg-gray-200 px-6 py-2 rounded-lg font-bold">Hủy</a>
        </div>
    </form>
</div>