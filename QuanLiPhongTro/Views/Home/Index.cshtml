@{
    ViewData["Title"] = "Tổng quan hệ thống";
    Layout = "_Layout";

    // Lấy dữ liệu từ Controller, nếu chưa có thì gán về 0 để tránh lỗi văng web
    int totalRooms = ViewBag.TotalRooms != null ? (int)ViewBag.TotalRooms : 0;
    int emptyRooms = ViewBag.EmptyRooms != null ? (int)ViewBag.EmptyRooms : 0;
    int tenants = ViewBag.Tenants != null ? (int)ViewBag.Tenants : 0;
    decimal revenue = ViewBag.Revenue != null ? (decimal)ViewBag.Revenue : 0;
    string studentId = ViewBag.StudentID != null ? ViewBag.StudentID.ToString() : "2415053122232";

    decimal[] chartData = ViewBag.MonthlyRevenue as decimal[] ?? new decimal[6] { 0, 0, 0, 0, 0, 0 };
    decimal maxVal = 1;
    foreach (var val in chartData) { if (val > maxVal) maxVal = val; }

    int rentedRooms = totalRooms - emptyRooms;
    int occupancyRate = totalRooms > 0 ? (int)Math.Round((double)rentedRooms / totalRooms * 100) : 0;
    string conicGradient = $"conic-gradient(#006591 0% {occupancyRate}%, #dee3e9 {occupancyRate}% 100%)";
}

<div class="mb-stack-gap">
    <h1 class="font-h1 text-h1 text-on-surface mb-2">Tổng quan hệ thống - SV: @studentId</h1>
    <p class="font-body-lg text-body-lg text-on-surface-variant">Chào mừng trở lại, đây là tình hình các bất động sản của bạn hôm nay.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-grid-gutter mb-stack-gap">
    <div class="bg-surface p-card-padding rounded-xl shadow-sm border border-outline-variant/50">
        <div class="flex justify-between items-start mb-4">
            <div>
                <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Tổng số phòng</p>
                <h3 class="font-h1 text-h1 mt-1 text-on-surface">@totalRooms</h3>
            </div>
            <div class="w-10 h-10 rounded-full bg-primary-container/20 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined">meeting_room</span>
            </div>
        </div>
        <div class="flex items-center gap-2 text-primary font-label-sm text-label-sm">
            <span class="material-symbols-outlined" style="font-variation-settings: 'opsz' 16;">trending_up</span>
            <span>Tự động cập nhật</span>
        </div>
    </div>

    <div class="bg-surface p-card-padding rounded-xl shadow-sm border border-outline-variant/50">
        <div class="flex justify-between items-start mb-4">
            <div>
                <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Phòng trống</p>
                <h3 class="font-h1 text-h1 mt-1 text-on-surface">@emptyRooms</h3>
            </div>
            <div class="w-10 h-10 rounded-full bg-tertiary-container/20 flex items-center justify-center text-tertiary">
                <span class="material-symbols-outlined">key_off</span>
            </div>
        </div>
        <div class="flex items-center gap-2 text-on-surface-variant font-label-sm text-label-sm">
            <span>Tỷ lệ trống @(100 - occupancyRate)%</span>
        </div>
    </div>

    <div class="bg-surface p-card-padding rounded-xl shadow-sm border border-outline-variant/50">
        <div class="flex justify-between items-start mb-4">
            <div>
                <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Phòng đang thuê</p>
                <h3 class="font-h1 text-h1 mt-1 text-on-surface">@rentedRooms</h3>
            </div>
            <div class="w-10 h-10 rounded-full bg-[#dcfce7] flex items-center justify-center text-[#166534]">
                <span class="material-symbols-outlined">how_to_reg</span>
            </div>
        </div>
        <div class="flex items-center gap-2 text-[#166534] font-label-sm text-label-sm">
            <span class="material-symbols-outlined" style="font-variation-settings: 'opsz' 16;">trending_up</span>
            <span>Đang mang lại doanh thu</span>
        </div>
    </div>

    <div class="bg-surface p-card-padding rounded-xl shadow-sm border border-outline-variant/50">
        <div class="flex justify-between items-start mb-4">
            <div>
                <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Doanh thu tháng</p>
                <h3 class="font-h1 text-h1 mt-1 text-on-surface">@(revenue >= 1000000 ? (revenue / 1000000).ToString("0.##") + "tr" : revenue.ToString("N0") + "đ")</h3>
            </div>
            <div class="w-10 h-10 rounded-full bg-primary-container/20 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined">payments</span>
            </div>
        </div>
        <div class="flex items-center gap-2 text-primary font-label-sm text-label-sm">
            <span class="material-symbols-outlined" style="font-variation-settings: 'opsz' 16;">trending_up</span>
            <span>Thống kê từ hóa đơn đã thu</span>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-grid-gutter">
    <div class="lg:col-span-2 flex flex-col gap-grid-gutter">
        <div class="bg-surface p-card-padding rounded-xl shadow-sm border border-outline-variant/50 flex flex-col h-[400px]">
            <div class="flex justify-between items-center mb-6">
                <h3 class="font-h3 text-h3 text-on-surface">Xu hướng doanh thu</h3>
                <select class="bg-surface-container-low border border-outline-variant rounded-md font-body-sm text-body-sm px-3 py-1 focus:border-primary outline-none">
                    <option>6 tháng qua</option>
                    <option>Năm nay</option>
                </select>
            </div>
            <div class="flex-1 relative w-full flex items-end justify-between px-4 pb-8 pt-4 gap-2">
                <div class="w-full bg-surface-container-highest h-full absolute left-0 bottom-0 opacity-10 rounded-lg pointer-events-none"></div>

                @for (int i = 0; i < 6; i++)
                {
                    decimal heightPercent = maxVal > 0 ? (chartData[i] / maxVal) * 100 : 10;
                    if (heightPercent < 10) heightPercent = 10;
                    bool isLast = (i == 5);
                    string bgClass = isLast ? "bg-primary" : "bg-primary/40 group-hover:bg-primary";
                    string textClass = isLast ? "opacity-100 font-bold" : "opacity-0 group-hover:opacity-100";
                    string monthTextClass = isLast ? "font-bold text-on-surface" : "text-on-surface-variant";
                    string displayValue = chartData[i] >= 1000000
                        ? (chartData[i] / 1000000).ToString("0.#") + "tr"
                        : (chartData[i] > 0 ? (chartData[i] / 1000).ToString("0") + "k" : "0");

                    <div class="flex-1 flex flex-col justify-end items-center group h-full">
                        <div class="w-full max-w-[40px] @bgClass transition-colors rounded-t-md relative" style="height: @((int)heightPercent)%;">
                            <span class="absolute -top-6 left-1/2 -translate-x-1/2 font-label-sm text-label-sm @textClass transition-opacity">@displayValue</span>
                        </div>
                        <span class="font-label-sm text-label-sm mt-2 @monthTextClass">Th@(i + 1)</span>
                    </div>
                }
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-grid-gutter">
            <div class="bg-surface p-card-padding rounded-xl shadow-sm border border-outline-variant/50 flex flex-col items-center justify-center min-h-[250px]">
                <h3 class="font-h3 text-h3 text-on-surface w-full text-left mb-6">Tỷ lệ lấp đầy</h3>
                <div class="relative w-40 h-40 rounded-full bg-surface-container-high flex items-center justify-center overflow-hidden" style="background: @conicGradient;">
                    <div class="absolute inset-0 m-4 bg-surface rounded-full flex flex-col items-center justify-center">
                        <span class="font-h1 text-h1 text-on-surface">@occupancyRate%</span>
                        <span class="font-label-sm text-label-sm text-on-surface-variant">Đã thuê</span>
                    </div>
                </div>
                <div class="flex w-full justify-center gap-6 mt-6">
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 rounded-full bg-primary"></div>
                        <span class="font-body-sm text-body-sm text-on-surface-variant">Đã thuê (@rentedRooms)</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="w-3 h-3 rounded-full bg-surface-container-highest border border-outline-variant"></div>
                        <span class="font-body-sm text-body-sm text-on-surface-variant">Trống (@emptyRooms)</span>
                    </div>
                </div>
            </div>

            <div class="bg-surface p-card-padding rounded-xl shadow-sm border border-outline-variant/50 flex flex-col">
                <h3 class="font-h3 text-h3 text-on-surface mb-4">Thao tác nhanh</h3>
                <div class="grid grid-cols-2 gap-3 flex-1">
                    <a href="/HopDong/Create" class="bg-surface-container-low hover:bg-surface-container-highest transition-colors rounded-lg flex flex-col items-center justify-center p-4 border border-outline-variant/30 group">
                        <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform mb-2">add_circle</span>
                        <span class="font-label-sm text-label-sm text-on-surface">Hợp đồng mới</span>
                    </a>
                    <a href="/ThanhToan/Create" class="bg-surface-container-low hover:bg-surface-container-highest transition-colors rounded-lg flex flex-col items-center justify-center p-4 border border-outline-variant/30 group">
                        <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform mb-2">receipt_long</span>
                        <span class="font-label-sm text-label-sm text-on-surface">Tạo hóa đơn</span>
                    </a>
                    <a href="/YeuCau/Create" class="bg-surface-container-low hover:bg-surface-container-highest transition-colors rounded-lg flex flex-col items-center justify-center p-4 border border-outline-variant/30 group">
                        <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform mb-2">build</span>
                        <span class="font-label-sm text-label-sm text-on-surface">Báo sửa chữa</span>
                    </a>
                    <a href="/KhachThue/Create" class="bg-surface-container-low hover:bg-surface-container-highest transition-colors rounded-lg flex flex-col items-center justify-center p-4 border border-outline-variant/30 group">
                        <span class="material-symbols-outlined text-primary group-hover:scale-110 transition-transform mb-2">group_add</span>
                        <span class="font-label-sm text-label-sm text-on-surface">Thêm khách</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-surface rounded-xl shadow-sm border border-outline-variant/50 overflow-hidden flex flex-col">
        <div class="p-card-padding border-b border-outline-variant/30 bg-surface-bright">
            <h3 class="font-h3 text-h3 text-on-surface">Hoạt động gần đây</h3>
        </div>
        <div class="flex-1 overflow-y-auto p-4 flex flex-col gap-4">
            <div class="flex gap-4 items-start pb-4 border-b border-outline-variant/20 last:border-0 last:pb-0">
                <div class="w-10 h-10 rounded-full bg-[#dcfce7] flex-shrink-0 flex items-center justify-center text-[#166534]">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'opsz' 20;">payments</span>
                </div>
                <div class="flex-1">
                    <p class="font-label-md text-label-md text-on-surface">Đã nhận thanh toán</p>
                    <p class="font-body-sm text-body-sm text-on-surface-variant mt-0.5">Phòng 102 - Nguyễn Văn A đã đóng 4.500.000 VNĐ tiền thuê tháng 6.</p>
                    <p class="font-label-sm text-label-sm text-outline mt-1">2 giờ trước</p>
                </div>
            </div>
            <div class="flex gap-4 items-start pb-4 border-b border-outline-variant/20 last:border-0 last:pb-0">
                <div class="w-10 h-10 rounded-full bg-tertiary-container/20 flex-shrink-0 flex items-center justify-center text-tertiary">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'opsz' 20;">build</span>
                </div>
                <div class="flex-1">
                    <p class="font-label-md text-label-md text-on-surface">Yêu cầu bảo trì</p>
                    <p class="font-body-sm text-body-sm text-on-surface-variant mt-0.5">Phòng 305 báo hỏng máy lạnh.</p>
                    <p class="font-label-sm text-label-sm text-outline mt-1">5 giờ trước</p>
                </div>
            </div>
            <div class="flex gap-4 items-start pb-4 border-b border-outline-variant/20 last:border-0 last:pb-0">
                <div class="w-10 h-10 rounded-full bg-primary-container/20 flex-shrink-0 flex items-center justify-center text-primary">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'opsz' 20;">draw</span>
                </div>
                <div class="flex-1">
                    <p class="font-label-md text-label-md text-on-surface">Hợp đồng mới đã ký</p>
                    <p class="font-body-sm text-body-sm text-on-surface-variant mt-0.5">Phòng 201 đã cho thuê cho Trần Thị B thời hạn 12 tháng.</p>
                    <p class="font-label-sm text-label-sm text-outline mt-1">Hôm qua</p>
                </div>
            </div>
            <div class="flex gap-4 items-start pb-4 border-b border-outline-variant/20 last:border-0 last:pb-0">
                <div class="w-10 h-10 rounded-full bg-[#dcfce7] flex-shrink-0 flex items-center justify-center text-[#166534]">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'opsz' 20;">payments</span>
                </div>
                <div class="flex-1">
                    <p class="font-label-md text-label-md text-on-surface">Đã nhận thanh toán</p>
                    <p class="font-body-sm text-body-sm text-on-surface-variant mt-0.5">Phòng 404 - Lê Văn C đã đóng 5.000.000 VNĐ.</p>
                    <p class="font-label-sm text-label-sm text-outline mt-1">Hôm qua</p>
                </div>
            </div>
            <div class="flex gap-4 items-start pb-4 border-b border-outline-variant/20 last:border-0 last:pb-0">
                <div class="w-10 h-10 rounded-full bg-error-container/50 flex-shrink-0 flex items-center justify-center text-error">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'opsz' 20;">logout</span>
                </div>
                <div class="flex-1">
                    <p class="font-label-md text-label-md text-on-surface">Chấm dứt hợp đồng</p>
                    <p class="font-body-sm text-body-sm text-on-surface-variant mt-0.5">Khách phòng 105 đã dời đi. Trạng thái phòng cập nhật thành Trống.</p>
                    <p class="font-label-sm text-label-sm text-outline mt-1">2 ngày trước</p>
                </div>
            </div>
        </div>
        <div class="p-3 border-t border-outline-variant/30 text-center">
            <button class="font-label-md text-label-md text-primary hover:underline">Xem tất cả hoạt động</button>
        </div>
    </div>
</div>